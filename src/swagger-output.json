                    "createdAt": {
                      "type": "string",
                      "example": "2024-01-01T00:00:00.000Z"
                    },
                    "replies": {
                      "type": "array",
                      "example": [],
                      "items": {}
                    }
                  }
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "400": {
            "description": "O ID fornecido não é um UUID válido."
          },
          "404": {
            "description": "Tweet a ser respondido não foi encontrado"
